# mitsume-blobs — content-addressed image store. /blobs holds flat files named
# by their SHA-256; the doc (synced by mitsume-sync) is the only place that
# knows what a hash means. The host Caddy proxies /blobs/* here with the
# prefix stripped, so this server only ever sees /<hash> paths.
#
# Blob root is /blobs, NOT /data — the official caddy image owns /data
# (XDG state, root-owned), which both pollutes the store and breaks writes
# as uid 1000. :8080 (unprivileged) so the container runs as uid 1000 with
# no capabilities. Inside `route`, written order is execution order — that
# matters: a bare `respond 405` would otherwise sort before webdav.

:8080 {
	root * /blobs

	route {
		respond /health 200

		# Immutable blobs: PUT to create, DELETE when the last canvas item
		# referencing the hash is removed (client refcounts via the doc).
		@write method PUT DELETE
		webdav @write

		# Forever-cache ONLY files that exist — an immutable header on a 404
		# would poison reads that happen before an upload lands.
		@readExisting {
			method GET HEAD
			file
		}
		header @readExisting Cache-Control "public, max-age=31536000, immutable"

		@read method GET HEAD
		file_server @read

		respond 405
	}
}
