# Radicale (CalDAV) connection. Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit real credentials.
#
# EXPO_PUBLIC_* vars are inlined into the JS bundle at build time (not secret).
# Acceptable here: the web build is same-origin behind Caddy on Tailscale and the
# Android APK is sideloaded to your own device. Move to secure-store later.
#
# URL notes:
#   prod (web, same-origin behind Caddy):  https://mitsume.<tailnet>.ts.net/dav/
#   web dev (local same-origin proxy):     http://localhost:8080/dav/
#   Android (native, no CORS):             https://catallenya.<tailnet>.ts.net:7000/  (or the /dav prod URL)
EXPO_PUBLIC_DAV_URL=https://your-host/dav/
EXPO_PUBLIC_DAV_USER=your-username
EXPO_PUBLIC_DAV_PASS=your-app-password
