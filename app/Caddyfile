# In-container static server for the exported web app (expo-router output:static).
# Reverse-proxying to Radicale is the HOST Caddy's job (see docs/Deploy.md) — this
# container only serves files, so it stays credential-free and trivially cacheable.
:80 {
	root * /srv
	encode gzip

	# Hashed bundles are content-addressed — cache forever. Everything else
	# (HTML shells, version.json) must revalidate so a normal refresh — and the
	# silent-reload check — always sees a freshly deployed version.
	@immutable path /_expo/static/*
	header @immutable Cache-Control "public, max-age=31536000, immutable"
	header ?Cache-Control "no-cache"

	# Per-route static HTML first (expo-router emits one .html per route), then the
	# client-side fallback for any route rendered after hydration.
	try_files {path} {path}.html /index.html
	file_server
}
