# Copy to tooling/dev-proxy/.env (gitignored) and fill in.
# Your Radicale origin as reachable from this machine (Tailscale URL).
RADICALE_ORIGIN=https://your-host:7000
# Server-side credential injection: base64 of "user:app-password".
# Generate with:  printf '%s:%s' 'user' 'app-password' | base64
RADICALE_BASIC_B64=dXNlcjphcHAtcGFzc3dvcmQ=
