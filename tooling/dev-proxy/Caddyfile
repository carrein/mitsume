# Dev-time same-origin proxy for WEB development (runs in Docker — nothing on the host).
#
# `expo start --web` serves on :8081, which is a different origin than Radicale —
# the browser would block CalDAV requests (CORS). This proxy puts Metro and Radicale
# behind ONE local origin, exactly like production:
#
#   http://localhost:8880/        → Metro dev server on the host (incl. HMR websocket)
#   http://localhost:8880/dav/*   → your Radicale (over Tailscale)
#
# Usage:
#   cp tooling/dev-proxy/.env.example tooling/dev-proxy/.env   # set RADICALE_ORIGIN
#   docker compose -f tooling/dev-proxy/compose.yml up -d      # start
#   docker compose -f tooling/dev-proxy/compose.yml down       # stop (removes container)
#
# app/.env for web dev:
#   EXPO_PUBLIC_DAV_URL=http://localhost:8880/dav/
#
# (Native Android dev is never subject to CORS — point it straight at the
# Tailscale URL and skip this proxy.)

:8880 {
	# Strip /dav before forwarding; X-Script-Name makes Radicale emit hrefs
	# under /dav so CalDAV discovery resolves through this proxy.
	handle_path /dav/* {
		reverse_proxy {$RADICALE_ORIGIN} {
			header_up X-Script-Name /dav
			header_up Host {upstream_hostport}
			# Server-side credential injection (base64 of user:app-password) —
			# clients send no Authorization; this replaces whatever they send.
			header_up Authorization "Basic {$RADICALE_BASIC_B64}"
		}
	}

	# host.docker.internal = the Mac, from inside the container (see compose.yml).
	handle {
		reverse_proxy host.docker.internal:8081
	}
}
