# Same-origin proxy for the e2e stack (compose.yml) — the test-Radicale twin of
# tooling/dev-proxy/Caddyfile.

:8881 {
	# Strip /dav before forwarding; X-Script-Name makes Radicale emit hrefs
	# under /dav so CalDAV discovery resolves through this proxy.
	handle_path /dav/* {
		reverse_proxy radicale:5232 {
			header_up X-Script-Name /dav
			header_up Host {upstream_hostport}
			# Throwaway creds ("test:test") for the throwaway server — nothing
			# secret. Radicale runs auth=none and takes the username as owner,
			# so discovery lands on the /test/ principal like production.
			header_up Authorization "Basic dGVzdDp0ZXN0"
		}
	}

	# host.docker.internal = the Mac, from inside the container (see compose.yml).
	handle {
		reverse_proxy host.docker.internal:8081
	}
}
